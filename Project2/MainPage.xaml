<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Project2.MainPage"
             Title="Movie Explorer"
             BackgroundColor="Black">
    <ScrollView>
      
        <VerticalStackLayout>
            <VerticalStackLayout Spacing="15">

                <Label Text="Movie Explorer"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   FontSize="30"/>
                
            <!--The message that appears when ran-->
            <Label Text="Welcome,Enter your name" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes ="Bold" TextColor="LightCyan" FontSize="30" />
                
                </VerticalStackLayout>
<!--This is the part where user's will be able to see their history and favorites-->
            <VerticalStackLayout x:Name="UserSection"
                                 IsVisible="False"
                                 >
                <Label Text="Profile"
                      FontAttributes="Bold"
                      FontSize="19"/>
                <HorizontalStackLayout Spacing="40">
                    <Button x:Name="FavoriteButton"
                            Text="Favorites"
                            Clicked="OnFavoriteClicked"
                            HeightRequest="40"
                            WidthRequest="100"
                            BackgroundColor="AliceBlue" />

                <Button x:Name="ViewedButton"
         Text="History"
         Clicked="OnViewedClicked"
         HeightRequest="40"
         WidthRequest="100"
        BackgroundColor="AliceBlue" />
                    </HorizontalStackLayout>
            </VerticalStackLayout>
            
            
                    <VerticalStackLayout
                        Spacing="15">
            <Label Text="Name:"/>
                <HorizontalStackLayout Spacing="5">
            <Entry x:Name="NameBox" 
                   Text="{Binding Name}"
                   Placeholder="Enter your name"
                  WidthRequest="500" />
            
                <Button x:Name="Name" 
                        Clicked ="OnStartClicked"
                        Text="Save"
                        HeightRequest="50"
                        WidthRequest="100"
                        BackgroundColor="AliceBlue"/>
            </HorizontalStackLayout>
            <!--searchbar function-->
            <SearchBar
           Text="{Binding SearchMovie}"
         SearchCommand = "{Binding SearchCommand}"
           SearchCommandParameter = "{Binding Text, Source ={RelativeSource Self}}"/>

            <CollectionView ItemsSource="{Binding Movies}"
SelectionMode="Single" 
SelectedItem="{Binding SelectedMovie}"
                SelectionChanged="selectionChanged">
                    <!-- Means you can only select one item-->

                
                
                <!-- For how each movie will look-->
                    <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="10">
                            <!-- Checkbox to favorite/unfavorite a movie-->
                                <CheckBox
                                    IsChecked ="{Binding IsFavorite}"
                                    VerticalOptions ="Center"/>
                            <Label Text="{Binding title}"
                                   FontAttributes="Bold"/>
                           
                            <Label Text="{Binding emoji}" FontSize="Small"/>
                            <Label Text="{Binding year}" FontSize="Small"/>
                            <Label Text="{Binding Genre}" FontSize="Small"/>
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
                </VerticalStackLayout>

                </VerticalStackLayout>
    </ScrollView>

</ContentPage>
 